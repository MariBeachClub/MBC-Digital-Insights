rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }

    function isValidUserSettings(data) {
      return data.keys().hasOnly(['webAppUrl', 'updatedAt']) || data.keys().hasOnly(['webAppUrl', 'updatedAt', 'userId']) &&
             data.webAppUrl is string && data.webAppUrl.size() <= 1000;
    }

    match /user_settings/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) &&
                    isValidUserSettings(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) &&
                    isValidUserSettings(incoming());
    }
  }
}
